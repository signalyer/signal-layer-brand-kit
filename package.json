{
  "name": "@signallayer/brand-kit",
  "version": "0.1.2",
  "description": "Signal Layer brand kit — design tokens, fonts, Logo/Footer/CursorGlow components, and brand assets. Source-only distribution: works with Vite, Next.js, or any bundler that handles TS/TSX from node_modules.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens/tailwind-preset.ts",
    "./tokens.css": "./src/tokens/tokens.css",
    "./assets/*": "./assets/*"
  },
  "files": [
    "src",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "signallayer",
    "signal-layer",
    "brand-kit",
    "design-system",
    "tailwind"
  ],
  "author": "Signal Layer <contact@signallayer.ai>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signalyer/signal-layer-brand-kit.git"
  },
  "homepage": "https://www.signallayer.ai",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "framer-motion": ">=11.0.0",
    "lucide-react": ">=0.300.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
